{
  "monitoring": {
    "process_interval": 3,
    "filesystem_interval": 5,
    "network_interval": 5,
    "watched_paths": [
      "C:\\Users"
    ],
    "excluded_processes": [
      "svchost.exe",
      "lsass.exe",
      "csrss.exe",
      "wininit.exe",
      "services.exe"
    ]
  },
  "alerts": {
    "max_per_hour": 100,
    "retention_days": 30,
    "email_notifications": false,
    "webhook_url": null
  },
  "database": {
    "retention_days": 90,
    "auto_cleanup": true,
    "max_size_mb": 500
  },
  "logging": {
    "level": "INFO",
    "max_file_size_mb": 10,
    "backup_count": 5
  }
}